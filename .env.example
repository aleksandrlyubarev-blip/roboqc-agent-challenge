# Neuron Vision Display — RomeoFlexVision
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-pro
# LOG_LEVEL=INFO
# Hard limit for a single pipeline run in the Streamlit UI (seconds).
# PIPELINE_TIMEOUT_SECONDS=300
# Per-tool-call timeout in the roboqc_agent orchestration layer (seconds).
# ROBOQC_TOOL_TIMEOUT_SECONDS=60
# SQLite path for QC report persistence. Defaults to :memory: (tests only) —
# set a persistent volume path in production or reports are lost on restart.
# ROBOQC_DB_PATH=/data/roboqc.db

# Claude Fable 5 reasoning service (docs/fable5_integration.md)
# Local dev ONLY — on Cloud Run the key comes from Secret Manager via --set-secrets.
# ANTHROPIC_API_KEY=
# ANTHROPIC_SECRET_ID=anthropic-api-key

# Arize Phoenix (partner track — Google Cloud Rapid Agent Hackathon)
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/v1/traces
PHOENIX_PROJECT_NAME=neuron-vision-display
