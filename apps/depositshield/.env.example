# Copy to .env.local for local dev. NEVER commit real values.
# On Vercel, set these as encrypted Environment Variables instead.

ANTHROPIC_API_KEY=sk-ant-...

AWS_REGION=eu-central-1
DEPOSITSHIELD_TABLE=depositshield
DEPOSITSHIELD_BUCKET=depositshield-uploads

# Local dev only; in production prefer a Vercel<->AWS OIDC role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional effort for the inspection call (low|medium|high|xhigh|max). Default high.
DEPOSITSHIELD_EFFORT=high
