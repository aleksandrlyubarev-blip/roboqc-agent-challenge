# Copy to .env.local for local dev. NEVER commit real values.
# On Vercel, set these as encrypted Environment Variables instead.

# Anthropic — the reasoning engine. Local dev only; production uses Vercel env.
ANTHROPIC_API_KEY=sk-ant-...

# AWS region for DynamoDB + S3
AWS_REGION=eu-central-1

# DynamoDB table (see infra/gradelens/dynamodb-table.yaml)
GRADELENS_TABLE=gradelens

# S3 bucket for uploaded device photos
GRADELENS_BUCKET=gradelens-uploads

# AWS credentials for local dev. In production prefer a Vercel<->AWS OIDC role
# over long-lived keys. The Vercel runtime reads these from env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: effort for the grading call (low|medium|high|xhigh|max). Default high.
GRADELENS_EFFORT=high
