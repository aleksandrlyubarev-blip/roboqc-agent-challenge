# Secrets and local config — never ship into the image
.env

# Version control
.git
.gitignore

# Python caches and bytecode
__pycache__/
*.pyc
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Backups
*.bak

# Sample / downloaded data (not needed at runtime)
examples/pcb_samples/

# CI, infra-as-code, docs and media — not needed inside the image.
# NB: infra/fable5/ must stay in the context — its Dockerfile COPYs the lock
# file from there when building from the repo root.
.github/
infra/monitoring/
infra/cloudrun/
bench/
tests/
docs/
video/

# Node and virtualenvs
node_modules
.venv

# Local audio fixtures and misc large files
*.wav
.DS_Store
